---
import Layout from '../layouts/Layout.astro';

const profileCompletion = 78;

type CardTone = 'primary' | 'secondary' | 'accent';

const kpiCards = [
  { label: 'Nowe kampanie', value: '12', hint: '+4 od wczoraj', tone: 'primary' },
  { label: 'Bieżące kampanie', value: '5', hint: '2 z deadline < 72h', tone: 'secondary' },
  { label: 'Zakończone kampanie', value: '24', hint: 'Śr. ocena 4.8/5', tone: 'accent' },
] satisfies Array<{ label: string; value: string; hint: string; tone: CardTone }>;

const toneClassByName = {
  primary: 'text-primary',
  secondary: 'text-secondary',
  accent: 'text-accent',
} as const;

const recommendedCampaigns = [
  {
    brand: 'GlowLab',
    title: 'Test serum rozświetlającego',
    category: 'Beauty',
    contentType: 'Reel + Story',
    deadline: '12 kwietnia',
    fit: '95% dopasowania',
  },
  {
    brand: 'SkinForm',
    title: 'Rutyna wieczorna dla cery mieszanej',
    category: 'Skincare',
    contentType: 'TikTok',
    deadline: '16 kwietnia',
    fit: '91% dopasowania',
  },
  {
    brand: 'LumiHair',
    title: 'Pielęgnacja włosów po zimie',
    category: 'Haircare',
    contentType: 'IG Carousel',
    deadline: '19 kwietnia',
    fit: '88% dopasowania',
  },
];

const activeCampaigns = [
  {
    brand: 'GlowLab',
    campaign: 'Serum rozświetlające',
    status: 'Wysłane',
    deadline: '10 kwietnia',
    assets: 'Brief + 3 materiały',
  },
  {
    brand: 'SkinForm',
    campaign: 'Rutyna nocna',
    status: 'Publikacja',
    deadline: '07 kwietnia',
    assets: 'Brief + moodboard',
  },
  {
    brand: 'LumiHair',
    campaign: 'Maska odbudowująca',
    status: 'Zakończone',
    deadline: '03 kwietnia',
    assets: 'Raport gotowy',
  },
];

const notifications = [
  { text: 'Nowa kampania: GlowLab • Test serum rozświetlającego', time: '2h temu' },
  { text: 'Deadline kampanii SkinForm za 48h', time: 'Dzisiaj' },
  { text: 'Twoja publikacja dla LumiHair została zatwierdzona', time: 'Wczoraj' },
];
---

<Layout title="Dashboard influencera – crezio.app">
  <main class="min-h-[calc(100vh-4rem)] px-4 py-8 sm:px-6">
    <section class="mx-auto w-full max-w-7xl space-y-6">
      <div class="flex flex-col gap-4 rounded-2xl border border-base-content/10 bg-base-100/40 p-6 shadow-sm lg:flex-row lg:items-center lg:justify-between">
        <div>
          <p class="text-sm text-base-content/70">Panel influencera</p>
          <h1 class="mt-1 text-3xl font-bold">Czesc, Marcin 👋</h1>
          <p class="mt-2 max-w-2xl text-base-content/70">
            Oto Twoj dzienny przeglad: nowe kampanie barterowe, status biezacych wspolprac i rekomendacje dopasowane do Twojego profilu.
          </p>
        </div>
        <div class="flex flex-wrap gap-2">
          <a href="/settings" class="btn btn-outline btn-sm border-base-content/30">Uzupelnij profil</a>
          <button type="button" class="btn-crezio-gradient btn-sm">Aktywuj Premium</button>
        </div>
      </div>

      <div class="grid gap-4 md:grid-cols-3">
        {kpiCards.map((card) => (
          <article class="rounded-2xl border border-base-content/10 bg-base-100/35 p-5">
            <p class="text-sm text-base-content/65">{card.label}</p>
            <p class={`mt-2 text-3xl font-bold ${toneClassByName[card.tone]}`}>{card.value}</p>
            <p class="mt-1 text-sm text-base-content/70">{card.hint}</p>
          </article>
        ))}
      </div>

      <div class="grid gap-6 xl:grid-cols-[2fr_1fr]">
        <section class="rounded-2xl border border-base-content/10 bg-base-100/35 p-5">
          <div class="flex items-center justify-between gap-3">
            <h2 class="text-xl font-semibold">Rekomendacje kampanii</h2>
            <span class="badge badge-secondary badge-outline">Dopasowane AI</span>
          </div>
          <div class="mt-4 space-y-3">
            {recommendedCampaigns.map((campaign) => (
              <article class="rounded-xl border border-base-content/10 bg-base-100/40 p-4">
                <div class="flex flex-wrap items-center justify-between gap-2">
                  <p class="font-semibold">{campaign.title}</p>
                  <span class="badge badge-primary badge-outline">{campaign.fit}</span>
                </div>
                <p class="mt-1 text-sm text-base-content/70">{campaign.brand} • {campaign.category}</p>
                <div class="mt-3 flex flex-wrap items-center gap-2 text-xs text-base-content/75">
                  <span class="rounded-full border border-base-content/15 px-2 py-1">{campaign.contentType}</span>
                  <span class="rounded-full border border-base-content/15 px-2 py-1">Deadline: {campaign.deadline}</span>
                </div>
                <div class="mt-4">
                  <button type="button" class="btn btn-sm btn-crezio-gradient rounded-full px-5">Zglos sie</button>
                </div>
              </article>
            ))}
          </div>
        </section>

        <aside class="space-y-4">
          <section class="rounded-2xl border border-base-content/10 bg-base-100/35 p-5">
            <h2 class="text-lg font-semibold">Wypelnienie profilu</h2>
            <p class="mt-2 text-sm text-base-content/70">
              Pelny profil zwieksza szanse na wybor do kampanii i widocznosc w rankingach marek.
            </p>
            <progress class="progress progress-primary mt-4 w-full" value={profileCompletion} max="100" />
            <p class="mt-2 text-sm font-medium">{profileCompletion}% kompletne</p>
            <a href="/settings" class="btn btn-sm btn-outline mt-4 w-full border-base-content/25">Przejdz do ustawien</a>
          </section>

          <section class="rounded-2xl border border-base-content/10 bg-base-100/35 p-5">
            <h2 class="text-lg font-semibold">Powiadomienia</h2>
            <ul class="mt-3 space-y-3">
              {notifications.map((notification) => (
                <li class="rounded-lg border border-base-content/10 bg-base-100/30 p-3">
                  <p class="text-sm">{notification.text}</p>
                  <p class="mt-1 text-xs text-base-content/60">{notification.time}</p>
                </li>
              ))}
            </ul>
          </section>
        </aside>
      </div>

      <section class="rounded-2xl border border-base-content/10 bg-base-100/35 p-5">
        <div class="flex flex-wrap items-center justify-between gap-3">
          <h2 class="text-xl font-semibold">Moje kampanie (mini CRM)</h2>
          <div class="flex flex-wrap gap-2">
            <button type="button" class="btn btn-xs btn-outline border-base-content/25">Beauty</button>
            <button type="button" class="btn btn-xs btn-outline border-base-content/25">TikTok</button>
            <button type="button" class="btn btn-xs btn-outline border-base-content/25">IG Reels</button>
          </div>
        </div>
        <div class="mt-4 overflow-x-auto">
          <table class="table table-zebra">
            <thead>
              <tr>
                <th>Marka</th>
                <th>Kampania</th>
                <th>Status</th>
                <th>Deadline</th>
                <th>Materialy</th>
              </tr>
            </thead>
            <tbody>
              {activeCampaigns.map((campaign) => (
                <tr>
                  <td>{campaign.brand}</td>
                  <td>{campaign.campaign}</td>
                  <td>
                    <span class="badge badge-outline">{campaign.status}</span>
                  </td>
                  <td>{campaign.deadline}</td>
                  <td>{campaign.assets}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>
    </section>
  </main>
</Layout>
