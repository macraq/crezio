---
import Layout from '../layouts/Layout.astro';
import InfluencerProfileSettings from '../components/InfluencerProfileSettings';
import SocialOAuthConnections from '../components/SocialOAuthConnections';
---

<Layout title="Ustawienia – crezio.app">
  <main class="min-h-screen bg-base-200 py-8">
    <div class="container max-w-2xl mx-auto px-4 space-y-8">
      <div>
        <h1 class="text-2xl font-bold mb-2">Ustawienia profilu</h1>
        <p class="text-base-content/70 mb-2">
          Uzupełnij dane, aby marki mogły Cię dopasować do kampanii beauty i barterowych — w duchu Crezio: przejrzystość i zaufanie.
        </p>
        <p class="text-sm text-base-content/60">
          Najpierw połącz konta OAuth (opcjonalnie), potem zapisz profil z linkami i adresem wysyłki.
        </p>
      </div>
      <SocialOAuthConnections
        client:load
        supabaseUrl={import.meta.env.PUBLIC_SUPABASE_URL ?? ''}
        supabaseAnonKey={import.meta.env.PUBLIC_SUPABASE_ANON_KEY ?? ''}
      />
      <InfluencerProfileSettings
        client:load
        supabaseUrl={import.meta.env.PUBLIC_SUPABASE_URL ?? ''}
        supabaseAnonKey={import.meta.env.PUBLIC_SUPABASE_ANON_KEY ?? ''}
      />
    </div>
  </main>
</Layout>
