---
import Layout from '../layouts/Layout.astro';
import SocialLinksSettings from '../components/SocialLinksSettings';
import SocialOAuthConnections from '../components/SocialOAuthConnections';
---

<Layout title="Ustawienia – Influe">
  <main class="min-h-screen bg-base-200 py-8">
    <div class="container max-w-2xl mx-auto px-4 space-y-8">
      <div>
        <h1 class="text-2xl font-bold mb-2">Ustawienia</h1>
        <p class="text-base-content/70 mb-6">Zarządzaj profilem i połączeniami z social media.</p>
      </div>
      <SocialOAuthConnections
        client:load
        supabaseUrl={import.meta.env.PUBLIC_SUPABASE_URL ?? ''}
        supabaseAnonKey={import.meta.env.PUBLIC_SUPABASE_ANON_KEY ?? ''}
      />
      <SocialLinksSettings
        client:load
        supabaseUrl={import.meta.env.PUBLIC_SUPABASE_URL ?? ''}
        supabaseAnonKey={import.meta.env.PUBLIC_SUPABASE_ANON_KEY ?? ''}
      />
    </div>
  </main>
</Layout>
