---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Influe – Influencer Marketing Platform">
  <main class="min-h-screen flex items-center justify-center bg-base-200">
    <div class="text-center">
      <h1 class="text-4xl font-bold text-primary">Influe</h1>
      <p class="mt-2 text-lg opacity-80">Panel influencera – MVP</p>
      <p class="mt-4 text-sm text-base-content/70">Landing i dashboard w budowie</p>
      <p class="mt-4">
        <a href="/login" class="btn btn-primary btn-sm mr-2">Zaloguj się</a>
        <a href="/signup" class="btn btn-outline btn-sm">Zarejestruj się</a>
      </p>
    </div>
  </main>
</Layout>
