---
import Layout from '../layouts/Layout.astro';
import LoginForm from '../components/LoginForm';
---

<Layout title="Logowanie – Influe Marki">
  <main class="min-h-screen flex flex-col bg-base-200">
    <div class="flex-1 flex flex-col items-center justify-center p-6">
      <h1 class="text-2xl font-bold mb-2">Logowanie</h1>
      <p class="text-base-content/70 mb-6">Panel marki / partnera</p>
      <LoginForm
        client:load
        supabaseUrl={import.meta.env.PUBLIC_SUPABASE_URL}
        supabaseAnonKey={import.meta.env.PUBLIC_SUPABASE_ANON_KEY}
        redirectTo="/"
      />
      <p class="mt-4 text-sm text-base-content/60">
        Nie masz konta? <a href="/signup" class="link">Zarejestruj markę</a>
      </p>
    </div>
  </main>
</Layout>
