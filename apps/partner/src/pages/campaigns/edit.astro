---
import Layout from '../../layouts/Layout.astro';
import RequireAuth from '../../components/RequireAuth';
import CreateCampaignForm from '../../components/CreateCampaignForm';
---

<Layout title="Edycja kampanii – crezio.app (Marki)">
  <RequireAuth
    client:load
    supabaseUrl={import.meta.env.PUBLIC_SUPABASE_URL}
    supabaseAnonKey={import.meta.env.PUBLIC_SUPABASE_ANON_KEY}
    loginHref="/login"
  />
  <main class="brand-container relative z-10 py-8 sm:py-10">
    <div class="mb-4">
      <a href="/dashboard" class="brand-link text-sm">← Wróć do dashboardu</a>
    </div>
    <CreateCampaignForm
      client:load
      editMode={true}
      supabaseUrl={import.meta.env.PUBLIC_SUPABASE_URL}
      supabaseAnonKey={import.meta.env.PUBLIC_SUPABASE_ANON_KEY}
    />
  </main>
</Layout>
