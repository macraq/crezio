---
import Layout from '../layouts/Layout.astro';
import SignupForm from '../components/SignupForm';
---

<Layout title="Rejestracja marki – crezio.app">
  <main class="brand-container relative z-10 flex min-h-[calc(100vh-4rem)] flex-col py-8">
    <div class="flex flex-1 flex-col items-center justify-center">
      <section class="brand-glass w-full max-w-md p-6 sm:p-8">
        <p class="text-xs font-semibold uppercase tracking-[0.22em] text-emerald-300/90">Nowe konto marki</p>
        <h1 class="brand-heading mt-3 text-2xl font-semibold text-white">Rejestracja</h1>
        <p class="mt-2 text-sm text-slate-300">Dołącz do platformy i rozpocznij kampanie barterowe z influencerami.</p>
      <SignupForm
        client:load
        supabaseUrl={import.meta.env.PUBLIC_SUPABASE_URL}
        supabaseAnonKey={import.meta.env.PUBLIC_SUPABASE_ANON_KEY}
        redirectTo="/dashboard"
      />
        <p class="mt-5 text-sm text-slate-300">
          Masz już konto? <a href="/login" class="brand-link">Zaloguj się</a>
        </p>
      </section>
    </div>
  </main>
</Layout>
