---
import Layout from '../layouts/Layout.astro';
import RequireAuth from '../components/RequireAuth';

const currentPlan = 'Medium';
const campaignLimit = 3;
const activeCampaigns = 2;
const pendingApplications = 34;
const selectedInfluencers = 12;
const completedCampaigns = 5;

const campaigns = [
  {
    name: 'Spring Glow Test Box',
    type: 'UGC Reels + Stories',
    status: 'Aktywna',
    applications: 21,
    selected: 8,
    deadline: '31.03.2026',
    autoStatus: true,
  },
  {
    name: 'Skin Barrier Reset',
    type: 'TikTok + Recenzja',
    status: 'Zbieranie zgłoszeń',
    applications: 13,
    selected: 4,
    deadline: '04.04.2026',
    autoStatus: false,
  },
];

const newestApplications = [
  {
    handle: '@kasia.beauty',
    followers: '18.4k',
    er: '6.2%',
    campaign: 'Spring Glow Test Box',
    status: 'Nowe zgłoszenie',
  },
  {
    handle: '@ania.skinlab',
    followers: '9.1k',
    er: '7.1%',
    campaign: 'Skin Barrier Reset',
    status: 'Do wyboru',
  },
  {
    handle: '@marta.dailycare',
    followers: '25.3k',
    er: '5.4%',
    campaign: 'Spring Glow Test Box',
    status: 'Wybrana',
  },
];
---
<Layout title="Dashboard – crezio.app (Marki)">
  <RequireAuth
    client:load
    supabaseUrl={import.meta.env.PUBLIC_SUPABASE_URL}
    supabaseAnonKey={import.meta.env.PUBLIC_SUPABASE_ANON_KEY}
    loginHref="/login"
  />
  <main class="brand-container relative z-10 py-8 sm:py-10">
    <section class="brand-glass p-6 sm:p-8">
      <div class="flex flex-col gap-5 lg:flex-row lg:items-end lg:justify-between">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-emerald-300/90">Dashboard marki</p>
          <h1 class="brand-heading mt-2 text-2xl font-bold text-white sm:text-4xl">Kampanie barterowe pod kontrolą</h1>
          <p class="mt-3 max-w-2xl text-sm text-slate-300 sm:text-base">
            Zarządzaj kampaniami, analizuj zgłoszenia influencerów i finalizuj raporty PDF w jednym panelu.
          </p>
        </div>
        <div class="flex w-full flex-col gap-2 sm:w-auto sm:flex-row">
          <button class="brand-cta-outline w-full sm:w-auto">Filtruj kampanie</button>
          <a href="/campaigns/new" class="brand-cta w-full sm:w-auto text-center">+ Dodaj kampanię</a>
        </div>
      </div>
    </section>

    <section class="mt-5 grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
      <article class="brand-glass p-4">
        <p class="text-xs uppercase tracking-wider text-slate-400">Pakiet</p>
        <p class="mt-2 text-xl font-semibold text-white">{currentPlan}</p>
        <p class="mt-1 text-sm text-slate-300">Limit kampanii: {activeCampaigns}/{campaignLimit}</p>
      </article>
      <article class="brand-glass p-4">
        <p class="text-xs uppercase tracking-wider text-slate-400">Zgłoszenia</p>
        <p class="mt-2 text-xl font-semibold text-white">{pendingApplications}</p>
        <p class="mt-1 text-sm text-slate-300">Nowe i w trakcie selekcji</p>
      </article>
      <article class="brand-glass p-4">
        <p class="text-xs uppercase tracking-wider text-slate-400">Wybrani influencerzy</p>
        <p class="mt-2 text-xl font-semibold text-white">{selectedInfluencers}</p>
        <p class="mt-1 text-sm text-slate-300">W statusie przygotowanie do wysyłki</p>
      </article>
      <article class="brand-glass p-4">
        <p class="text-xs uppercase tracking-wider text-slate-400">Zakończone kampanie</p>
        <p class="mt-2 text-xl font-semibold text-white">{completedCampaigns}</p>
        <p class="mt-1 text-sm text-slate-300">Gotowe do eksportu raportów PDF</p>
      </article>
    </section>

    <section class="mt-5 grid gap-5 xl:grid-cols-[1.3fr_1fr]">
      <article class="brand-glass p-5">
        <div class="mb-4 flex items-center justify-between gap-3">
          <h2 class="brand-heading text-lg font-semibold text-white sm:text-xl">Aktywne kampanie</h2>
          <span class="rounded-full border border-emerald-300/30 bg-emerald-500/10 px-3 py-1 text-xs text-emerald-200">
            {activeCampaigns}/{campaignLimit} w użyciu
          </span>
        </div>
        <div class="space-y-3">
          {
            campaigns.map((campaign) => (
              <div class="rounded-xl border border-white/10 bg-white/5 p-4">
                <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
                  <h3 class="text-base font-semibold text-white">{campaign.name}</h3>
                  <span class="rounded-full border border-violet-300/30 bg-violet-500/10 px-2.5 py-1 text-xs text-violet-200">
                    {campaign.status}
                  </span>
                </div>
                <p class="mt-2 text-sm text-slate-300">{campaign.type}</p>
                <div class="mt-3 grid gap-2 text-xs text-slate-300 sm:grid-cols-4">
                  <span>Zgłoszenia: {campaign.applications}</span>
                  <span>Wybrani: {campaign.selected}</span>
                  <span>Deadline: {campaign.deadline}</span>
                  <span>{campaign.autoStatus ? 'Auto status: TAK' : 'Auto status: NIE'}</span>
                </div>
              </div>
            ))
          }
        </div>
      </article>

      <article class="brand-glass p-5">
        <h2 class="brand-heading text-lg font-semibold text-white sm:text-xl">Najnowsze zgłoszenia</h2>
        <div class="mt-4 space-y-3">
          {
            newestApplications.map((application) => (
              <div class="rounded-xl border border-white/10 bg-white/5 p-4">
                <div class="flex items-center justify-between gap-3">
                  <p class="font-medium text-white">{application.handle}</p>
                  <span class="text-xs text-emerald-200">{application.status}</span>
                </div>
                <p class="mt-2 text-xs text-slate-300">{application.campaign}</p>
                <div class="mt-2 flex gap-4 text-xs text-slate-300">
                  <span>Followers: {application.followers}</span>
                  <span>ER: {application.er}</span>
                </div>
              </div>
            ))
          }
        </div>
      </article>
    </section>

    <section class="mt-5 grid gap-5 lg:grid-cols-2">
      <article class="brand-glass p-5">
        <h2 class="brand-heading text-lg font-semibold text-white">Abonament i dostęp</h2>
        <p class="mt-2 text-sm text-slate-300">
          Bez aktywnego pakietu tworzenie kampanii i wyszukiwanie influencerów jest zablokowane.
        </p>
        <ul class="mt-4 space-y-2 text-sm text-slate-200">
          <li class="rounded-lg border border-white/10 bg-white/5 px-3 py-2">Basic - 1 aktywna kampania</li>
          <li class="rounded-lg border border-emerald-300/30 bg-emerald-500/10 px-3 py-2">Medium - 3 aktywne kampanie</li>
          <li class="rounded-lg border border-white/10 bg-white/5 px-3 py-2">Platinum - 10 aktywnych kampanii</li>
        </ul>
      </article>
      <article class="brand-glass p-5">
        <h2 class="brand-heading text-lg font-semibold text-white">Raporty i zakończenie kampanii</h2>
        <p class="mt-2 text-sm text-slate-300">
          Po zakończeniu kampanii generujesz raport PDF z wynikami: zasięg, wyświetlenia i najlepsze publikacje.
        </p>
        <div class="mt-4 flex flex-col gap-2 sm:flex-row">
          <button class="brand-cta-outline w-full sm:w-auto">Podgląd raportów</button>
          <button class="brand-cta w-full sm:w-auto">Generuj PDF</button>
        </div>
      </article>
    </section>
  </main>
</Layout>
