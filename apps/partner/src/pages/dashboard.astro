---
import Layout from '../layouts/Layout.astro';
import RequireAuth from '../components/RequireAuth';
import BrandDashboardCampaigns from '../components/BrandDashboardCampaigns';
import BrandDashboardKpi from '../components/BrandDashboardKpi';
import BrandDashboardRecentApplications from '../components/BrandDashboardRecentApplications';
---
<Layout title="Dashboard – crezio.app (Marki)">
  <RequireAuth
    client:load
    supabaseUrl={import.meta.env.PUBLIC_SUPABASE_URL}
    supabaseAnonKey={import.meta.env.PUBLIC_SUPABASE_ANON_KEY}
    loginHref="/login"
  />
  <main class="brand-container relative z-10 py-8 sm:py-10">
    <section class="brand-glass p-6 sm:p-8">
      <div class="flex flex-col gap-5 lg:flex-row lg:items-end lg:justify-between">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-emerald-300/90">Dashboard marki</p>
          <h1 class="brand-heading mt-2 text-2xl font-bold text-white sm:text-4xl">Kampanie barterowe pod kontrolą</h1>
          <p class="mt-3 max-w-2xl text-sm text-slate-300 sm:text-base">
            Zarządzaj kampaniami, analizuj zgłoszenia influencerów i finalizuj raporty PDF w jednym panelu.
          </p>
        </div>
        <div class="flex w-full flex-col gap-2 sm:w-auto sm:flex-row">
          <button class="brand-cta-outline w-full sm:w-auto">Filtruj kampanie</button>
          <a href="/campaigns/new" class="brand-cta w-full sm:w-auto text-center">+ Dodaj kampanię</a>
        </div>
      </div>
    </section>

    <BrandDashboardKpi
      client:load
      supabaseUrl={import.meta.env.PUBLIC_SUPABASE_URL}
      supabaseAnonKey={import.meta.env.PUBLIC_SUPABASE_ANON_KEY}
    />

    <section class="mt-5 grid gap-5 xl:grid-cols-[1.3fr_1fr]">
      <BrandDashboardCampaigns
        client:load
        supabaseUrl={import.meta.env.PUBLIC_SUPABASE_URL}
        supabaseAnonKey={import.meta.env.PUBLIC_SUPABASE_ANON_KEY}
      />

      <BrandDashboardRecentApplications
        client:load
        supabaseUrl={import.meta.env.PUBLIC_SUPABASE_URL}
        supabaseAnonKey={import.meta.env.PUBLIC_SUPABASE_ANON_KEY}
      />
    </section>

    <section class="mt-5 grid gap-5 lg:grid-cols-2">
      <article class="brand-glass p-5">
        <h2 class="brand-heading text-lg font-semibold text-white">Abonament i dostęp</h2>
        <p class="mt-2 text-sm text-slate-300">
          Bez aktywnego pakietu tworzenie kampanii i wyszukiwanie influencerów jest zablokowane.
        </p>
        <ul class="mt-4 space-y-2 text-sm text-slate-200">
          <li class="rounded-lg border border-white/10 bg-white/5 px-3 py-2">Basic - 1 aktywna kampania</li>
          <li class="rounded-lg border border-emerald-300/30 bg-emerald-500/10 px-3 py-2">Medium - 3 aktywne kampanie</li>
          <li class="rounded-lg border border-white/10 bg-white/5 px-3 py-2">Platinum - 10 aktywnych kampanii</li>
        </ul>
      </article>
      <article class="brand-glass p-5">
        <h2 class="brand-heading text-lg font-semibold text-white">Raporty i zakończenie kampanii</h2>
        <p class="mt-2 text-sm text-slate-300">
          Po zakończeniu kampanii generujesz raport PDF z wynikami: zasięg, wyświetlenia i najlepsze publikacje.
        </p>
        <div class="mt-4 flex flex-col gap-2 sm:flex-row">
          <button class="brand-cta-outline w-full sm:w-auto">Podgląd raportów</button>
          <button class="brand-cta w-full sm:w-auto">Generuj PDF</button>
        </div>
      </article>
    </section>
  </main>
</Layout>
