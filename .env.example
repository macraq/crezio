# Supabase – lokalnie: po `supabase start` uruchom `supabase status` i wklej:
#   Project URL → PUBLIC_SUPABASE_URL
#   Publishable (lub anon) → PUBLIC_SUPABASE_ANON_KEY
# crezio.app używa portów 54331 (API), 54332 (DB), 54333 (Studio) – żeby nie kolidować z innymi projektami.
PUBLIC_SUPABASE_URL=http://127.0.0.1:54331
PUBLIC_SUPABASE_ANON_KEY=your-publishable-or-anon-key

# Panel marki – strona /subscription (opcjonalnie CTA kontakt); /abonament przekierowuje tutaj
# PUBLIC_CONTACT_EMAIL=hello@example.com
# PUBLIC_CONTACT_URL=https://example.com/kontakt

# Opcjonalnie – Edge Functions / backend
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
